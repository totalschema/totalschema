<FindBugsFilter>

    <Match>
        <Class name="io.github.totalschema.totalschema_maven_plugin.HelpMojo" />
        <Bug pattern="UI_INHERITANCE_UNSAFE_GETRESOURCE" />
        <!-- Framework generated code: the generated class will not be extended -->
    </Match>

    <Match>
        <Class name="io.github.totalschema.connector.shell.ShellScriptConnector" />
        <Method name="execute" />
        <Bug pattern="NP_NULL_ON_SOME_PATH_FROM_RETURN_VALUE" />
        <!-- Objects.requireNonNull is used to prevent unexpected null values -->
    </Match>

</FindBugsFilter>